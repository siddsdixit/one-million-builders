{
  "day": 5,
  "title": "Plan Architecture",
  "structural_checks": [
    {
      "id": "architecture_exists",
      "type": "file_exists",
      "path": ".onemillion/architecture.md"
    },
    {
      "id": "sprints_directory_exists",
      "type": "directory_exists",
      "path": ".onemillion/sprints"
    },
    {
      "id": "sprint_briefs_exist",
      "type": "file_exists_glob",
      "patterns": [".onemillion/sprints/*.md"],
      "min_match_count": 1
    }
  ],
  "code_quality_checks": [
    {
      "id": "architecture_sections",
      "type": "markdown_required_sections",
      "path": ".onemillion/architecture.md",
      "required_headings": [
        "Product Type",
        "Backend Path",
        "Tenancy",
        "Security",
        "Data Model",
        "API",
        "Frontend",
        "Deployment",
        "Scalability"
      ]
    },
    {
      "id": "product_type_recorded",
      "type": "file_contains",
      "path": ".onemillion/architecture.md",
      "any_of_strings": [
        "web app",
        "mobile-first",
        "agent",
        "hybrid"
      ]
    },
    {
      "id": "backend_path_recorded",
      "type": "file_contains",
      "path": ".onemillion/architecture.md",
      "any_of_strings": [
        "Supabase-only",
        "Supabase only",
        "Next.js route",
        "server action",
        "FastAPI"
      ]
    },
    {
      "id": "tenancy_model_recorded",
      "type": "file_contains",
      "path": ".onemillion/architecture.md",
      "any_of_strings": [
        "single-user",
        "single tenant",
        "multi-tenant",
        "tenant_id",
        "organization_id",
        "public/community"
      ]
    },
    {
      "id": "security_model_recorded",
      "type": "file_contains",
      "path": ".onemillion/architecture.md",
      "any_of_strings": [
        "Row Level Security",
        "RLS",
        "authorization",
        "owner_id",
        "tenant_id"
      ]
    },
    {
      "id": "course_stack_named",
      "type": "file_contains",
      "path": ".onemillion/architecture.md",
      "required_strings": ["Next.js", "Supabase", "Vercel"],
      "any_of_strings": ["MUI", "Material Design", "Material UI"]
    },
    {
      "id": "sprint_brief_has_build_contract",
      "type": "file_contains",
      "path_pattern": ".onemillion/sprints/*.md",
      "required_strings": [
        "Acceptance Criteria",
        "Verification Gate"
      ],
      "any_of_strings": [
        "Design Notes",
        "Frontend Tasks",
        "Backend Tasks",
        "Server Tasks"
      ]
    }
  ],
  "manual_checks": [
    {
      "id": "product_type_approved",
      "ask": "Did you approve the product type decision: web app, mobile-first responsive app, agent, or hybrid?"
    },
    {
      "id": "backend_path_approved",
      "ask": "Did you approve the backend path decision: Supabase-only unless FastAPI is clearly justified?"
    },
    {
      "id": "security_tenancy_approved",
      "ask": "Did you review and approve the security and tenancy model before moving to build?"
    },
    {
      "id": "plan_validation_complete",
      "ask": "Did validate-plan pass, or were its findings resolved before moving to build?"
    }
  ]
}
